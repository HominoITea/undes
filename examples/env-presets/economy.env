# ECONOMY PRESET
# Goal: minimize cost and token usage.

CONTEXT_MAX_FILES=120

AI_CFG__PROVIDER__ANTHROPIC__EXECUTION=sequential
AI_CFG__PROVIDER__OPENAI__EXECUTION=parallel
AI_CFG__PROVIDER__GOOGLE__ENABLED=0

AI_CFG__AGENT__PROMPT_ENGINEER__ENABLED=0
AI_CFG__AGENT__TESTER__ENABLED=0
AI_CFG__AGENT__DEVILS_ADVOCATE__ENABLED=0

AI_RATE_LIMIT_CLAUDE_MIN_INTERVAL_MS=65000
AI_CFG__AGENT__SYNTHESIZER__MIN_INTERVAL_MS=65000

AI_CFG__PROVIDER__ANTHROPIC__MAX_OUTPUT_TOKENS=1400
AI_CFG__PROVIDER__OPENAI__MAX_OUTPUT_TOKENS=2200

AI_CFG__DEFAULT__RETRY_MAX_RETRIES=2
AI_CFG__DEFAULT__RETRY_BASE_DELAY_MS=1000
AI_CFG__DEFAULT__RETRY_MAX_DELAY_MS=30000
AI_CFG__DEFAULT__RETRY_RATE_LIMIT_DELAY_MS=65000

AI_CFG__DEFAULT__TOOL_MAX_TURNS=4
AI_CFG__DEFAULT__TOOL_MAX_TOTAL_FILE_BYTES=140000
