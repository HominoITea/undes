# Example .ai.env for a real Next.js + TypeScript project
# Copy to project root as ".ai.env" and replace with real keys.

CLAUDE_API_KEY=sk-ant-your-real-key
GEMINI_API_KEY=AIzaSyYourRealKey
OPENAI_API_KEY=sk-proj-your-real-key

# Context build tuning
CONTEXT_MAX_FILES=320
CONTEXT_REDACT=1

# Provider execution mode
AI_CFG__PROVIDER__ANTHROPIC__EXECUTION=sequential
AI_CFG__PROVIDER__GOOGLE__EXECUTION=parallel
AI_CFG__PROVIDER__OPENAI__EXECUTION=parallel
# Optional switches:
# AI_CFG__PROVIDER__GOOGLE__ENABLED=0
# AI_CFG__AGENT__REVIEWER__ENABLED=0

# Retry behavior
AI_CFG__DEFAULT__RETRY_MAX_RETRIES=3
AI_CFG__DEFAULT__RETRY_BASE_DELAY_MS=1000
AI_CFG__DEFAULT__RETRY_MAX_DELAY_MS=30000
AI_CFG__DEFAULT__RETRY_RATE_LIMIT_DELAY_MS=65000

# Rate limit throttle (important for Claude synthesizer on low TPM tiers)
# Set to 0 to disable Claude-wide proactive throttling.
AI_RATE_LIMIT_CLAUDE_MIN_INTERVAL_MS=65000
AI_CFG__AGENT__SYNTHESIZER__MIN_INTERVAL_MS=65000

# Output token limits
AI_CFG__PROVIDER__ANTHROPIC__MAX_OUTPUT_TOKENS=2048
AI_CFG__PROVIDER__OPENAI__MAX_OUTPUT_TOKENS=4096
AI_CFG__PROVIDER__GOOGLE__MAX_OUTPUT_TOKENS=4096

# Tool loop limits
AI_CFG__DEFAULT__TOOL_MAX_TURNS=5
AI_CFG__DEFAULT__TOOL_MAX_TOTAL_FILE_BYTES=204800

# Notes:
# - Keep this file local (do not commit).
# - For large repos, reduce max files in light mode:
#   npm run ai:light -- --prompt="..."
